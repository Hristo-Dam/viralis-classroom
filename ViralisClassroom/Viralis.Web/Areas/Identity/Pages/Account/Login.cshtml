@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">

    <!-- Left panel -->
    <div class="auth-panel">
        <div class="auth-panel-grid"></div>
        <div class="auth-panel-glow"></div>

@*         <a asp-controller="Home" asp-action="Index" class="auth-panel-brand">
            <span class="brand-dot"></span>
            Viralis
        </a> *@

        <div class="auth-panel-content">
            <h2>Welcome<br />back.</h2>
            <p>Sign in to access your classrooms, assignments, and everything your school has to offer.</p>

            <ul class="auth-panel-features">
                <li>
                    <span class="auth-feature-check">✓</span>
                    View and manage your classrooms
                </li>
                <li>
                    <span class="auth-feature-check">✓</span>
                    Submit and track assignments
                </li>
                <li>
                    <span class="auth-feature-check">✓</span>
                    Message teachers and classmates
                </li>
            </ul>
        </div>

        <div style="position:relative; color: #2d3748; font-size: 0.78rem;">
            © @DateTime.Now.Year Viralis
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-box">

            <h1>Sign in</h1>
            <p class="auth-sub">
                Don't have an account?
                <a asp-page="./Register">Create one</a>
            </p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="auth-validation-summary">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="auth-field">
                    <label asp-for="Input.Email">Email address</label>
                    <input asp-for="Input.Email"
                           autocomplete="username"
                           placeholder="you@school.com" />
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Password">Password</label>
                    <input asp-for="Input.Password"
                           type="password"
                           autocomplete="current-password"
                           placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </div>

                <div class="auth-extras">
                    <label class="auth-checkbox">
                        <input asp-for="Input.RememberMe" type="checkbox" />
                        Remember me
                    </label>
                    <a class="auth-forgot" asp-page="./ForgotPassword">Forgot password?</a>
                </div>

                <button type="submit" class="btn-auth-submit">
                    Sign in →
                </button>
            </form>

            <div class="auth-divider">or</div>

            <p style="text-align:center; color: var(--nav-muted); font-size:0.85rem;">
                New to Viralis?
                <a asp-page="./Register" style="color:var(--accent); text-decoration:none; font-weight:500;">
                    Create a free account
                </a>
            </p>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}