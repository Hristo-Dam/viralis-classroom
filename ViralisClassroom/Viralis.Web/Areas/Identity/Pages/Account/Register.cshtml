@page
@model RegisterModel
@{
    ViewData["Title"] = "Create account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">

    <!-- Left panel -->
    <div class="auth-panel">
        <div class="auth-panel-grid"></div>
        <div class="auth-panel-glow"></div>

@*         <a asp-controller="Home" asp-action="Index" class="auth-panel-brand">
            <span class="brand-dot"></span>
            Viralis
        </a> *@

        <div class="auth-panel-content">
            <h2>Join your<br />school today.</h2>
            <p>Create your account and connect with your classrooms, teachers, and assignments in minutes.</p>

            <ul class="auth-panel-features">
                <li>
                    <span class="auth-feature-check">✓</span>
                    Students — join classrooms with a code
                </li>
                <li>
                    <span class="auth-feature-check">✓</span>
                    School admins — manage your teachers
                </li>
                <li>
                    <span class="auth-feature-check">✓</span>
                    Free to use for everyone
                </li>
            </ul>
        </div>

        <div style="position:relative; color: #2d3748; font-size: 0.78rem;">
            © @DateTime.Now.Year Viralis
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-box">

            <h1>Create account</h1>
            <p class="auth-sub">
                Already have an account?
                <a asp-page="./Login">Sign in</a>
            </p>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="auth-field">
                    <label asp-for="Input.Email">Email address</label>
                    <input asp-for="Input.Email"
                           autocomplete="username"
                           placeholder="you@school.com" />
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Password">Password</label>
                    <input asp-for="Input.Password"
                           type="password"
                           autocomplete="new-password"
                           placeholder="At least 6 characters" />
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.ConfirmPassword">Confirm password</label>
                    <input asp-for="Input.ConfirmPassword"
                           type="password"
                           autocomplete="new-password"
                           placeholder="Repeat your password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
                </div>

                <div class="auth-field">
                    <label>I am registering as a</label>
                    <div class="role-selector">
                        <div class="role-option">
                            <input type="radio" asp-for="Input.Role"
                                   value="Student" id="role-student" />
                            <label for="role-student">
                                <span class="role-icon">🎒</span>
                                Student
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" asp-for="Input.Role"
                                   value="SchoolAdmin" id="role-admin" />
                            <label for="role-admin">
                                <span class="role-icon">🏫</span>
                                School Admin
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="Input.Role" class="field-error"></span>
                </div>

                <button type="submit" class="btn-auth-submit">
                    Create account →
                </button>
            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}