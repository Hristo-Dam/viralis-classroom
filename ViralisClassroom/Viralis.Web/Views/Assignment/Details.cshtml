@model Viralis.Common.ViewModels.Assignment.AssignmentDetailViewModel

@{
    ViewData["Title"] = Model.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/css/classroom.css" />
    <link rel="stylesheet" href="~/css/assignment.css" />
}

<div class="classroom-banner">
    <div class="container">
        <a asp-controller="Classroom" asp-action="Details"
           asp-route-id="@Model.ClassroomId"
           style="color: var(--accent); font-size:0.875rem; text-decoration:none;">
            ← Back to classroom
        </a>
        <div class="classroom-banner-content" style="margin-top:0.5rem;">
            <div>
                <h1 class="classroom-banner-title">@Model.Title</h1>
                <p style="color: @(Model.IsOverdue ? "var(--color-overdue, #fc8181)" : "var(--text-muted)"); margin:0.3rem 0 0; font-size:0.875rem;">
                    Due @Model.DueDate.ToString("MMM dd, yyyy 'at' HH:mm")
                    @if (Model.IsOverdue)
                    {
                        <span> · Overdue</span>
                    }
                </p>
                <p style="color: var(--text-muted); margin:0.2rem 0 0; font-size:0.8rem;">
                    Posted @Model.AssignmentDate.ToString("MMM dd, yyyy 'at' HH:mm")
                </p>
            </div>
        </div>
    </div>
</div>

<div class="container assignment-body">
    <div class="assignment-layout">

        <!-- Left: Instructions -->
        <main class="assignment-main">
            <div class="assignment-card">
                <h3 class="assignment-section-title">Instructions</h3>
                <p class="assignment-description">@Model.Description</p>

                @if (Model.AssignmentFiles.Any())
                {
                    <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border);">
                        <p class="form-label">Assignment Files</p>
                        <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:0.5rem;">
                            @foreach (var file in Model.AssignmentFiles)
                            {
                                <a href="@file.FilePath" download="@file.FileName"
                                   style="display:inline-flex; align-items:center; gap:0.4rem;
                                          background:rgba(79,142,247,0.08); border:1px solid rgba(79,142,247,0.2);
                                          border-radius:8px; padding:0.4rem 0.85rem;
                                          color:var(--accent); font-size:0.875rem; text-decoration:none;
                                          transition: all 0.18s ease;">
                                    📎 @file.FileName
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (Model.IsTeacher)
            {
                <!-- Teacher: Submission overview -->
                <div class="assignment-card" style="margin-top:1.5rem;">
                    <h3 class="assignment-section-title">
                        Student Submissions
                        <span class="members-count">
                            @Model.Submissions.Count(s => s.HasSubmitted) / @Model.Submissions.Count
                        </span>
                    </h3>

                    @if (!Model.Submissions.Any())
                    {
                        <p style="color:var(--text-muted); font-size:0.9rem;">
                            No students enrolled yet.
                        </p>
                    }
                    else
                    {
                        <div class="submission-list">
                            @foreach (var sub in Model.Submissions)
                            {
                                <div class="submission-row">
                                    <div class="member-avatar">
                                        @sub.StudentEmail.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="submission-info">
                                        <span class="submission-email">@sub.StudentEmail</span>
                                        <span class="submission-status @(sub.HasSubmitted ? "status-submitted" : "status-missing")">
                                            @(sub.HasSubmitted ? $"Submitted {sub.SubmittedOn?.ToString("MMM dd")}" : "Missing")
                                        </span>
                                        @if (sub.TextContent != null)
                                        {
                                            <p style="font-size:0.85rem; color:var(--text-muted); margin:0.3rem 0 0;">
                                                @sub.TextContent
                                            </p>
                                        }
                                        @if (sub.Files.Any())
                                        {
                                            <div style="margin-top:0.4rem; display:flex; flex-wrap:wrap; gap:0.4rem;">
                                                @foreach (var file in sub.Files)
                                                {
                                                    <a href="@file.FilePath" download="@file.FileName"
                                                       style="font-size:0.8rem; color:var(--accent); text-decoration:none;">
                                                        📎 @file.FileName
                                                    </a>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="submission-grade">
                                        @if (sub.Grade.HasValue)
                                        {
                                            <span class="grade-chip">@sub.Grade / 100</span>
                                        }
                                        @if (sub.HasSubmitted)
                                        {
                                            <form asp-action="Grade" method="post" class="grade-form">
                                                <input type="hidden" name="SubmissionId" value="@sub.SubmissionId" />
                                                <input type="hidden" name="AssignmentId" value="@Model.Id" />
                                                <input type="hidden" name="ClassroomId" value="@Model.ClassroomId" />
                                                <input type="number" name="Grade" min="0" max="100"
                                                       value="@sub.Grade" placeholder="Grade"
                                                       class="grade-input" />
                                                <input type="text" name="Feedback"
                                                       value="@sub.Feedback" placeholder="Feedback (optional)"
                                                       class="feedback-input" />
                                                <button type="submit" class="grade-btn">
                                                    @(sub.Grade.HasValue ? "Update" : "Save")
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </main>

        <!-- Right: Submission panel (students only) -->
        @if (!Model.IsTeacher)
        {
            <aside class="assignment-sidebar">
                <div class="submission-panel">

                    @if (TempData["Success"] != null)
                    {
                        <div class="viralis-alert viralis-alert-success" style="margin-bottom:1rem;">
                            @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="form-error-summary" style="margin-bottom:1rem;">
                            @TempData["Error"]
                        </div>
                    }

                    @if (Model.MySubmission != null)
                    {
                        <h4 class="submission-panel-title">Your Submission</h4>
                        <div class="submission-meta">
                            Submitted @Model.MySubmission.SubmittedOn.ToString("MMM dd 'at' HH:mm")
                        </div>

                        @if (Model.MySubmission.TextContent != null)
                        {
                            <p class="submission-text">@Model.MySubmission.TextContent</p>
                        }

                        @if (Model.MySubmission.FileNames.Any())
                        {
                            <div class="file-chips" style="margin-top:0.5rem;">
                                @foreach (var file in Model.MySubmission.FileNames)
                                {
                                    <div class="file-chip">
                                        <span class="file-chip-name">
                                            <span class="file-chip-icon">📎</span>
                                            <span class="file-chip-name-text" title="@file">@file</span>
                                        </span>
                                    </div>
                                }
                            </div>
                        }

                        @if (Model.MySubmission.Grade.HasValue)
                        {
                            <div class="grade-result" style="margin-top:1rem;">
                                <span class="grade-label">Grade</span>
                                <span class="grade-value">@Model.MySubmission.Grade / 100</span>
                            </div>
                        }

                        @if (Model.MySubmission.TeacherFeedback != null)
                        {
                            <div class="feedback-box" style="margin-top:0.75rem;">
                                <span class="feedback-label">Feedback</span>
                                <p>@Model.MySubmission.TeacherFeedback</p>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- Submit form -->
                        <h4 class="submission-panel-title">Your Work</h4>
                        <form asp-action="Submit" method="post" enctype="multipart/form-data">
                            <input type="hidden" asp-for="Id" name="AssignmentId" />
                            <input type="hidden" asp-for="ClassroomId" />

                            <div class="form-field">
                                <label class="form-label">Text Response (optional)</label>
                                <textarea name="TextContent" class="form-textarea" rows="4"
                                          placeholder="Add a comment or note..."></textarea>
                            </div>

                            <div class="form-field">
                                <label class="form-label">Attach Files (optional)</label>
                                <div class="file-upload-zone" id="submitDropZone">
                                    <input type="file" id="submitFileInput" name="Files" multiple accept="*/*" />
                                    <div class="file-upload-icon">📎</div>
                                    <p class="file-upload-text">
                                        <span>Click to add files</span> or drag and drop
                                    </p>
                                </div>
                                <div class="file-chips" id="submitFileChips"></div>
                            </div>

                            <button type="submit" class="btn-primary-action"
                                    style="width:100%; text-align:center; padding:0.75rem; border:none; cursor:pointer; margin-top:0.5rem;">
                                Submit Assignment
                            </button>
                        </form>
                    }

                </div>
            </aside>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (!Model.IsTeacher && Model.MySubmission == null)
    {
        <script>
            createFileManager('submitFileInput', 'submitFileChips');
        </script>
    }
}
