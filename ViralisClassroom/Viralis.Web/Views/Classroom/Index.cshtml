@model IEnumerable<Viralis.Common.ViewModels.Classroom.ClassroomListViewModel>

@{
    ViewData["Title"] = "My Classrooms";
    bool isTeacher = User.IsInRole("Teacher");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>My Classrooms</h2>
        <div class="d-flex gap-2">
            @if (isTeacher)
            {
                <a asp-action="Create" class="btn btn-primary">+ Create Classroom</a>
            }
            <a asp-action="Join" class="btn btn-outline-secondary">Join by Code</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You have no classrooms yet.
            @if (isTeacher)
            {
                <span>Create one or join an existing classroom.</span>
            }
            else
            {
                <span>Ask your teacher for a join code.</span>
            }
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var classroom in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@classroom.Name</h5>
                            <p class="card-text text-muted">@classroom.Subject</p>
                            <span class="badge @(classroom.IsTeacher ? "bg-primary" : "bg-success")">
                                @(classroom.IsTeacher ? "Teacher" : "Student")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
