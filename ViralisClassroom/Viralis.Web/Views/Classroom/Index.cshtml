@model IEnumerable<Viralis.Common.ViewModels.Classroom.ClassroomListViewModel>

@{
    ViewData["Title"] = "My Classrooms";
    bool isTeacher = User.IsInRole("Teacher");
}

<!-- Header Banner -->
<div class="classroom-banner">
    <div class="container">
        <div class="classroom-banner-content">
            <div>
                <p class="classroom-banner-subject">Dashboard</p>
                <h1 class="classroom-banner-title">My Classrooms</h1>
            </div>
            <div class="d-flex gap-2">
                @if (isTeacher)
                {
                    <a asp-action="Create" class="btn-hero-primary" style="font-size:0.875rem; padding:0.55rem 1.25rem;">
                        + Create Classroom
                    </a>
                }
                <a asp-action="Join" class="btn-hero-secondary" style="font-size:0.875rem; padding:0.55rem 1.25rem;">
                    Join by Code
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Content -->
<div class="container" style="padding-top: 2rem; padding-bottom: 3rem;">

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🏫</div>
            <p>No classrooms yet.</p>
            @if (isTeacher)
            {
                <span class="empty-sub">Create your first classroom to get started.</span>
            }
            else
            {
                <span class="empty-sub">Ask your teacher for a join code to get started.</span>
            }
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var classroom in Model)
            {
                <div class="col">
                    <a asp-action="Details" asp-route-id="@classroom.Id" class="classroom-card-link">
                        <div class="classroom-card">
                            <div class="classroom-card-header">
                                <span class="classroom-subject">@classroom.Subject</span>
                                <h3 class="classroom-name">@classroom.Name</h3>
                            </div>
                            <div class="classroom-card-footer">
                                <span class="classroom-role-badge @(classroom.IsTeacher ? "badge-teacher" : "badge-student")">
                                    @(classroom.IsTeacher ? "Teacher" : "Student")
                                </span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }

</div>
