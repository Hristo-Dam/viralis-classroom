@model Viralis.Common.ViewModels.Classroom.JoinClassroomViewModel

@{
    ViewData["Title"] = "Join Classroom";
}

<!-- Header Banner -->
<div class="classroom-banner">
    <div class="container">
        <a asp-action="Index" style="color: var(--accent); font-size:0.875rem; text-decoration:none;">
            ← Back to classrooms
        </a>
        <h1 class="classroom-banner-title" style="margin-top:0.5rem;">Join a Classroom</h1>
    </div>
</div>

<div class="container" style="max-width:480px; padding: 2rem 1rem;">
    <div class="assignment-card">
        <p style="color: var(--text-muted); font-size:0.9rem; margin-bottom:1.5rem;">
            Enter the join code your teacher shared with you.
        </p>

        <form asp-action="Join" method="post">

            <div asp-validation-summary="ModelOnly" class="form-error-summary"
                 style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="form-field">
                <label asp-for="JoinCode" class="form-label">Join Code</label>
                <input asp-for="JoinCode" class="form-input" placeholder="e.g. A1B2C3"
                       style="letter-spacing: 3px; font-size: 1.1rem; text-transform: uppercase;" />
                <span asp-validation-for="JoinCode" class="form-field-error"></span>
            </div>

            <div style="display:flex; gap:1rem; margin-top:1.75rem;">
                <button type="submit" class="btn-primary-action"
                        style="flex:1; text-align:center; padding:0.75rem; border:none; cursor:pointer;">
                    Join Classroom
                </button>
                <a asp-action="Index" class="btn-secondary-action"
                   style="flex:1; text-align:center; padding:0.75rem;">
                    Cancel
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
