@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero -->
<section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="container">
        <div class="hero-content">

            <div class="hero-eyebrow">
                <span class="hero-eyebrow-dot"></span>
                Built for modern schools
            </div>

            <h1 class="hero-title">
                Where classrooms<br />
                come <span class="highlight">alive</span>
            </h1>

            <p class="hero-subtitle">
                Viralis connects teachers and students in one seamless space —
                assignments, discussions, and feedback all in one place.
            </p>

            <div class="hero-actions">
                <a asp-area="Identity" asp-page="/Account/Register" class="btn-hero-primary">
                    Get started free →
                </a>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn-hero-secondary">
                    Sign in
                </a>
            </div>

        </div>
    </div>
</section>

<!-- Features -->
<section class="features">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col">
                <p class="section-label">Everything you need</p>
                <h2 class="section-title">One platform.<br />Every role.</h2>
            </div>
            <div class="col-auto d-none d-md-block">
                <p class="section-sub text-end">
                    From school administrators to students,
                    Viralis gives everyone the tools they need.
                </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon icon-blue">🏫</div>
                    <h4>Classrooms</h4>
                    <p>Teachers create classrooms and invite students with a simple join code. No setup needed.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon icon-green">📋</div>
                    <h4>Assignments</h4>
                    <p>Post assignments with due dates, collect submissions, and give feedback all in one place.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon icon-yellow">💬</div>
                    <h4>Discussions</h4>
                    <p>Built-in messaging per classroom keeps conversations focused and organised.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon icon-purple">👥</div>
                    <h4>School Admin</h4>
                    <p>Administrators manage teacher accounts and keep the school's roster up to date.</p>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- CTA -->
<section class="cta-strip">
    <div class="container position-relative">
        <h2>Ready to get started?</h2>
        <p>Join your school on Viralis today — it takes less than a minute.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn-hero-primary">
                Create your account →
            </a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn-hero-secondary">
                Already have an account
            </a>
        </div>
    </div>
</section>