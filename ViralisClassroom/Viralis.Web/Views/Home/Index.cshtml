@using Microsoft.AspNetCore.Identity
@inject SignInManager<Viralis.Data.Models.ApplicationUser> SignInManager
@inject UserManager<Viralis.Data.Models.ApplicationUser> UserManager

@{
    ViewBag.Title = "Home page";
}

<div class="container mt-5">

    @if (!SignInManager.IsSignedIn(User))
    {
        <!-- NOT LOGGED IN -->
        <div class="text-center">
            <h1 class="display-5 mb-4">Viralis Virtual Classroom</h1>
            <p class="lead mb-4">
                Join classrooms, attend live lessons, submit assignments, and collaborate in real time.
            </p>

            <div class="d-flex justify-content-center gap-3">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg">
                    Login
                </a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary btn-lg">
                    Register
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- LOGGED IN -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Your Classrooms</h2>

            @if (User.IsInRole("Teacher"))
            {
                <a asp-controller="Classroom"
                   asp-action="Create"
                   class="btn btn-success">
                    + Create Classroom
                </a>
            }
        </div>

        <!-- Placeholder for classrooms -->
        <!-- You will replace this with a model later -->
        <div class="alert alert-info">
            Classrooms will appear here once wired to the service layer.
        </div>

        <!-- Example layout for later -->
        <div class="row row-cols-1 row-cols-md-3 g-4 d-none">
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Classroom Name</h5>
                        <p class="card-text text-muted">
                            Short classroom description
                        </p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="#" class="btn btn-outline-primary w-100">
                            Enter Classroom
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

</div>
