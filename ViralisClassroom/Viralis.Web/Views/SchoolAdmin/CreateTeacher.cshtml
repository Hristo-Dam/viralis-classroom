@model Viralis.Common.ViewModels.SchoolAdmin.CreateTeacherViewModel

@{
    ViewData["Title"] = "Add Teacher";
}

<!-- Header Banner -->
<div class="classroom-banner">
    <div class="container">
        <a asp-action="Index" style="color: var(--accent); font-size:0.875rem; text-decoration:none;">
            ← Back to teachers
        </a>
        <h1 class="classroom-banner-title" style="margin-top:0.5rem;">Add Teacher Account</h1>
    </div>
</div>

<div class="container" style="max-width:540px; padding: 2rem 1rem;">
    <div class="assignment-card">
        <p style="color: var(--text-muted); font-size:0.9rem; margin-bottom:1.5rem;">
            The teacher will use these credentials to sign in. Share the temporary password with them securely.
        </p>

        <form asp-action="CreateTeacher" method="post">

            <div asp-validation-summary="ModelOnly" class="form-error-summary"
                 style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="form-field">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-input" placeholder="teacher@school.com" />
                <span asp-validation-for="Email" class="form-field-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="TemporaryPassword" class="form-label">Temporary Password</label>
                <input asp-for="TemporaryPassword" type="password" class="form-input"
                       placeholder="Min. 8 characters" />
                <span asp-validation-for="TemporaryPassword" class="form-field-error"></span>
            </div>

            <div style="display:flex; gap:1rem; margin-top:1.75rem;">
                <button type="submit" class="btn-primary-action"
                        style="flex:1; text-align:center; padding:0.75rem; border:none; cursor:pointer;">
                    Create Teacher Account
                </button>
                <a asp-action="Index" class="btn-secondary-action"
                   style="flex:1; text-align:center; padding:0.75rem;">
                    Cancel
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
