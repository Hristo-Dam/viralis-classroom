@model IEnumerable<Viralis.Data.Models.ApplicationUser>

@{
    ViewData["Title"] = "School Administration";
}

<!-- Header Banner -->
<div class="classroom-banner">
    <div class="container">
        <div class="classroom-banner-content">
            <div>
                <p class="classroom-banner-subject">Administration</p>
                <h1 class="classroom-banner-title">Manage Teachers</h1>
            </div>
            <a asp-action="CreateTeacher" class="btn-hero-primary" style="font-size:0.875rem; padding:0.55rem 1.25rem;">
                + Add Teacher
            </a>
        </div>
    </div>
</div>

<!-- Content -->
<div class="container" style="padding-top: 2rem; padding-bottom: 3rem;">

    @if (TempData["Success"] != null)
    {
        <div class="viralis-alert viralis-alert-success">
            @TempData["Success"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">👩‍🏫</div>
            <p>No teachers yet.</p>
            <span class="empty-sub">Click "Add Teacher" to create a teacher account.</span>
        </div>
    }
    else
    {
        <div class="viralis-table-wrap">
            <table class="viralis-table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var teacher in Model)
                    {
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:0.75rem;">
                                    <div class="user-avatar" style="width:32px; height:32px; font-size:0.75rem; flex-shrink:0;">
                                        @teacher.Email?.Substring(0, 1).ToUpper()
                                    </div>
                                    <span>@teacher.Email</span>
                                </div>
                            </td>
                            <td style="text-align:right;">
                                <form asp-action="DeleteTeacher" method="post" class="d-inline"
                                      onsubmit="return confirm('Remove this teacher from your school?')">
                                    <input type="hidden" name="userId" value="@teacher.Id" />
                                    <button type="submit" class="btn-danger-action">
                                        Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>
