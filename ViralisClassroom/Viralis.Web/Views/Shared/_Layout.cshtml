<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Viralis</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
    <link rel="stylesheet" href="~/css/classroom.css" />
    <link rel="stylesheet" href="~/css/assignment.css" />
    @await RenderSectionAsync("Styles", required: false)

</head>
<body>

    <nav class="viralis-nav navbar navbar-expand-lg">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-dot"></span>
                Viralis
            </a>

            <button class="navbar-toggler border-secondary" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navContent">

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">
                        @if (User.IsInRole("Teacher") || User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Classroom" asp-action="Index">
                                    🏫 My Classrooms
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("School Administrator"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SchoolAdmin" asp-action="Index">
                                    👥 Manage Teachers
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Users">
                                    ⚙️ Admin Panel
                                </a>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <ul class="navbar-nav me-auto"></ul>
                }

                <div class="d-flex align-items-center gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="user-badge">
                            <div class="user-avatar">
                                @User.Identity.Name?.Substring(0, 1).ToUpper()
                            </div>
                            <span class="d-none d-lg-inline">@User.Identity.Name</span>
                        </div>

                        @if (User.IsInRole("Teacher"))
                        {
                            <span class="role-pill role-teacher">Teacher</span>
                        }
                        else if (User.IsInRole("School Administrator"))
                        {
                            <span class="role-pill role-schooladmin">School Admin</span>
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            <span class="role-pill role-admin">Admin</span>
                        }
                        else
                        {
                            <span class="role-pill role-student">Student</span>
                        }

                        <div class="nav-divider"></div>

                        <form asp-area="Identity" asp-page="/Account/Logout"
                              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                              method="post">
                            <button type="submit" class="btn-nav-logout">Sign out</button>
                        </form>
                    }
                    else
                    {
                        <a class="nav-link btn-nav-login"
                           asp-area="Identity" asp-page="/Account/Login">Log in</a>
                        <a class="nav-link btn-nav-register"
                           asp-area="Identity" asp-page="/Account/Register">Register</a>
                    }
                </div>

            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>